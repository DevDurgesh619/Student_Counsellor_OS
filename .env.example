# Copy to .env and fill in. Do NOT commit .env.
# Vendor-native env names per CLAUDE_CODE.md §5 / §13 — do NOT rename.

# --- Supabase / Postgres ---
# Local Supabase CLI defaults shown; replace for staging/prod.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- WGC own config (WGC_ prefix) ---
WGC_LOG_LEVEL=info
WGC_NODE_ENV=development

# --- Anthropic Claude (Phase 5+) ---
WGC_ANTHROPIC_API_KEY=

# --- OpenAI Whisper (Phase 5+, voice transcription) ---
WGC_OPENAI_API_KEY=

# --- Postmark (Phase 8, email) ---
WGC_POSTMARK_API_KEY=
WGC_POSTMARK_FROM_DOMAIN=reports.wgc.in

# --- Google Vision (Phase 7, OCR) ---
WGC_GOOGLE_VISION_KEY=

# --- Google Calendar (Phase 4) ---
WGC_GOOGLE_CALENDAR_CLIENT_ID=
WGC_GOOGLE_CALENDAR_CLIENT_SECRET=
WGC_GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8787/auth/google/callback
WGC_GOOGLE_CALENDAR_WEBHOOK_URL=
WGC_CALENDAR_SYNC_ENABLED=false
# Symmetric key (>=16 chars) for at-rest encryption of stored OAuth tokens.
WGC_TOKEN_ENCRYPTION_KEY=

# --- Google OAuth for Supabase user auth (Phase 6 follow-on) ---
# Sign-in flow: /login -> Google consent -> /auth/callback -> /api/me routes.
# Reuse the Calendar OAuth client below OR create a separate Web client in
# Google Cloud Console. Add this redirect URI to that client:
#   http://127.0.0.1:54321/auth/v1/callback
WGC_GOOGLE_AUTH_CLIENT_ID=
WGC_GOOGLE_AUTH_CLIENT_SECRET=

# --- Spinach (Phase 6) ---
# Zapier fallback path uses the webhook secret. Primary ingestion is MCP.
WGC_SPINACH_WEBHOOK_SECRET=
# Per-counsellor MCP OAuth. Register a Spinach OAuth client at
# https://app.spinach.ai/settings/integrations (or dynamic registration via MCP).
WGC_SPINACH_CLIENT_ID=
WGC_SPINACH_CLIENT_SECRET=
WGC_SPINACH_REDIRECT_URI=http://localhost:8787/auth/spinach/callback
# MCP server URL — override only if Spinach moves it.
WGC_SPINACH_MCP_URL=https://mcp.spinach.ai/mcp

# --- Internal RPC between workers-cron and the API (Phase 6+).
# Min 16 chars. Generate with: openssl rand -hex 32
WGC_INTERNAL_API_SECRET=

# --- Sentry (Phase 9 hardening; safe to leave empty in dev) ---
WGC_SENTRY_DSN=

# --- Public origins (consumed by web/admin and by the API when building URLs) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
# apps/web's public origin. Used by the API to build the onboarding form URL
# (and any future emails that link back into the dashboard). Different from
# the API URL in production (api.wgc.in vs app.wgc.in).
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000
