{
  "name": "@wgc/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "echo 'no lint configured yet' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file=../../.env src/seed.ts"
  },
  "dependencies": {
    "@wgc/config": "workspace:*",
    "@wgc/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
